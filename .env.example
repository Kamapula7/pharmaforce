# Required
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dbname"
NEXTAUTH_SECRET="generate-a-secure-random-string"
NEXTAUTH_URL="https://your-domain.com"

# Admin panel
ADMIN_PASSWORD="your-admin-password"

# SMTP (order confirmation emails)
SMTP_USER=""
