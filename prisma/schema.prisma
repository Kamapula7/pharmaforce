generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  nameEn   String
  nameDe   String?
  namePl   String?
  nameFr   String?
  image    String?
  order    Int       @default(0)
  products Product[]

  @@map("categories")
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  nameEn      String
  nameDe      String?
  namePl      String?
  nameFr      String?
  descEn      String      @db.Text
  descDe      String?     @db.Text
  descPl      String?     @db.Text
  descFr      String?     @db.Text
  compositionEn String?   @db.Text
  howToUseEn  String?     @db.Text
  price       Float
  currency    String      @default("EUR")
  stock       Int         @default(0)
  sku         String?     @unique
  brand       String?
  weight      String?
  servings    Int?
  images      String[]
  featured    Boolean     @default(false)
  active      Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  reviews     Review[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("products")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      UserRole @default(CUSTOMER)
  orders    Order[]
  reviews   Review[]
  createdAt DateTime @default(now())

  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  email       String
  firstName   String
  lastName    String
  phone       String?
  country     String
  city        String
  address     String
  zip         String
  notes       String?     @db.Text
  total       Float
  currency    String      @default("EUR")
  bankRef     String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int
  price     Float
  nameEn    String

  @@map("order_items")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  rating    Int
  comment   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("reviews")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  country   String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@map("page_views")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEn     String
  titleDe     String?
  titlePl     String?
  titleFr     String?
  contentEn   String   @db.Text
  contentDe   String?  @db.Text
  contentPl   String?  @db.Text
  contentFr   String?  @db.Text
  excerpt     String?  @db.Text
  image       String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}
